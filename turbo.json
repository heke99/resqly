{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "NODE_ENV",
    "APP_ENV",
    "APP_BASE_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "GOOGLE_MAPS_BROWSER_KEY",
    "GOOGLE_MAPS_SERVER_KEY",
    "GOOGLE_MAPS_ROUTES_API_ENABLED",
    "GOOGLE_MAPS_ROUTE_MATRIX_ENABLED",
    "GOOGLE_MAPS_GEOCODING_ENABLED",
    "BANKID_PROVIDER",
    "BANKID_ENV",
    "BANKID_MOCK_ENABLED",
    "TIC_API_BASE_URL",
    "TIC_API_KEY",
    "TIC_DEFAULT_PROVIDER",
    "TIC_WEBHOOK_SECRET",
    "TIC_CALLBACK_BASE_URL",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "EMAIL_REPLY_TO",
    "NOTIFICATIONS_EMAIL_ENABLED",
    "EXPO_PUSH_ENABLED",
    "EXPO_PUSH_URL",
    "EXPO_PROJECT_ID",
    "EXPO_PUBLIC_PROJECT_ID",
    "WEBHOOK_SIGNING_SECRET",
    "ENCRYPTION_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
