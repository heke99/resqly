# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Google Maps Platform
#   - BROWSER key: restricted, used by client SDK (Maps JS / RN map view)
#   - SERVER key:  unrestricted-by-referrer, used ONLY server-side for
#                  Geocoding / Routes / Route Matrix. Never expose to client.
# ---------------------------------------------------------------------------
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_MAPS_ROUTES_API_ENABLED=true

# ---------------------------------------------------------------------------
# BankID
#   BANKID_ENV: mock | test | production
#   When BANKID_MOCK_ENABLED=true the in-memory mock adapter is used and no
#   external calls are made (recommended for local development & CI).
# ---------------------------------------------------------------------------
BANKID_ENV=test
BANKID_API_URL=
BANKID_CERT_PATH=
BANKID_CERT_PASSWORD=
BANKID_MOCK_ENABLED=true

# ---------------------------------------------------------------------------
# Platform
# ---------------------------------------------------------------------------
APP_ENV=development
APP_BASE_URL=http://localhost:3000
WEBHOOK_SIGNING_SECRET=
# 32-byte (64 hex chars) key used for at-rest encryption of sensitive fields.
ENCRYPTION_KEY=
