# ---------------------------------------------------------------------------
# Resqly environment template — PRODUCTION DEFAULTS
# ---------------------------------------------------------------------------
# Copy to .env / app-level .env.local and fill in real values.
# Never commit real keys. Service-role keys must only be used server-side.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

FIRST_SUPERADMIN_EMAIL=

# ---------------------------------------------------------------------------
# Public URLs and domains
# ---------------------------------------------------------------------------
APP_ENV=production
PLATFORM_BASE_DOMAIN=resqly.se
APP_BASE_URL=https://app.resqly.se
NEXT_PUBLIC_API_URL=https://api.resqly.se
NEXT_PUBLIC_CUSTOMER_WEB_URL=https://app.resqly.se
NEXT_PUBLIC_PORTAL_WEB_URL=https://portal.resqly.se
NEXT_PUBLIC_ADMIN_WEB_URL=https://admin.resqly.se
TIC_CALLBACK_BASE_URL=https://api.resqly.se

# ---------------------------------------------------------------------------
# Google Maps Platform
# Browser key: restricted by HTTP referrer / app identifiers.
# Server key: restricted to backend usage + APIs only. Never expose in app/browser.
# Required APIs: Maps JS, Geocoding, Routes, Places, Maps SDK iOS/Android.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_MAPS_ROUTES_API_ENABLED=true
GOOGLE_MAPS_ROUTE_MATRIX_ENABLED=true
GOOGLE_MAPS_GEOCODING_ENABLED=true

# ---------------------------------------------------------------------------
# TIC BankID — production
# ---------------------------------------------------------------------------
BANKID_PROVIDER=tic
BANKID_ENV=production
BANKID_MOCK_ENABLED=false
TIC_API_BASE_URL=https://id.tic.io/api/v1
TIC_API_KEY=
TIC_DEFAULT_PROVIDER=bankid
TIC_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Resend email — production
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Resqly <no-reply@mail.resqly.se>
EMAIL_REPLY_TO=support@resqly.se
NOTIFICATIONS_EMAIL_ENABLED=true

# ---------------------------------------------------------------------------
# Platform security
# ---------------------------------------------------------------------------
WEBHOOK_SIGNING_SECRET=
# 32-byte+ strong secret used as pepper for hashing personal numbers.
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Partner API / workers
# ---------------------------------------------------------------------------
PORT=4000
WORKER_INTERVAL_MS=15000


# ---------------------------------------------------------------------------
# SMS fallback provider (operational fallback only; avoid sensitive payloads)
# ---------------------------------------------------------------------------
SMS_PROVIDER=
SMS_API_KEY=
SMS_FROM=Resqly
SMS_ENABLED=false

# ---------------------------------------------------------------------------
# Expo mobile apps / push
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_URL=https://api.resqly.se
EXPO_PUBLIC_PROJECT_ID=
EXPO_PROJECT_ID=
EXPO_PUSH_ENABLED=true
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
