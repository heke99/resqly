# ---------------------------------------------------------------------------
# Resqly environment template
# ---------------------------------------------------------------------------
# Copy this file to .env or app-level .env.local files and fill in real values.
# Never commit real keys. Service-role keys must only be used server-side.

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional first-superadmin bootstrap for apps/admin-web.
# When no platform admin exists, the first authenticated user matching this
# email can be promoted server-side. Remove after bootstrap if preferred.
FIRST_SUPERADMIN_EMAIL=

# ---------------------------------------------------------------------------
# Public URLs and domains
# ---------------------------------------------------------------------------
APP_ENV=development
PLATFORM_BASE_DOMAIN=resqly.se
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_CUSTOMER_WEB_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_WEB_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_WEB_URL=http://localhost:3002

# Production recommendation:
# NEXT_PUBLIC_CUSTOMER_WEB_URL=https://app.resqly.se
# NEXT_PUBLIC_PORTAL_WEB_URL=https://portal.resqly.se
# NEXT_PUBLIC_ADMIN_WEB_URL=https://admin.resqly.se
# NEXT_PUBLIC_API_URL=https://api.resqly.se

# ---------------------------------------------------------------------------
# Google Maps Platform
#   Browser key: restricted, used by client SDK (Maps JS / RN map view)
#   Server key: used ONLY server-side for Geocoding / Routes / Route Matrix.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_MAPS_ROUTES_API_ENABLED=true

# ---------------------------------------------------------------------------
# BankID
#   BANKID_ENV: mock | test | production
# ---------------------------------------------------------------------------
BANKID_ENV=test
BANKID_API_URL=
BANKID_CERT_PATH=
BANKID_CERT_PASSWORD=
BANKID_MOCK_ENABLED=true

# ---------------------------------------------------------------------------
# Platform security
# ---------------------------------------------------------------------------
WEBHOOK_SIGNING_SECRET=
# 32-byte (64 hex chars) key used for at-rest encryption of sensitive fields
# and as the pepper for hashing personal numbers.
ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Partner API / workers
# ---------------------------------------------------------------------------
PORT=4000
WORKER_INTERVAL_MS=15000

# ---------------------------------------------------------------------------
# Expo mobile apps
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_URL=http://localhost:4000
# Driver app token for local/dev only. Do not expose production API keys in app bundles.
EXPO_PUBLIC_DRIVER_TOKEN=
